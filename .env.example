# Airflow secrets — copy this file to .env and fill in your values
# Generate a Fernet key:
#   python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_FERNET_KEY="your_generated_fernet_key_here"

# Generate a webserver secret key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY="your_generated_secret_key_here"

# Snowflake Configuration
SNOWFLAKE_ACCOUNT="your_account.snowflakecomputing.com"
SNOWFLAKE_USER="SVC_YOUR_SERVICE"
SNOWFLAKE_PRIVATE_KEY_PATH="/path/to/rsa_key.p8"
SNOWFLAKE_KEY_PASSPHRASE=""
SNOWFLAKE_WAREHOUSE="COMPUTE_WH"
SNOWFLAKE_DATABASE="YOUR_DB"
SNOWFLAKE_ROLE="SYSADMIN"
NANO_CHOP_ENV="prod"
